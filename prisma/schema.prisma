generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Provider {
  id          String   @id @default(cuid())
  fullName    String
  email       String   @unique
  phone       String
  serviceId   String
  cityId      String
  description String?
  picturePath String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
